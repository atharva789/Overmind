{
  "family": "overmind-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::048270140082:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::048270140082:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "overmind-container",
      "image": "048270140082.dkr.ecr.us-east-2.amazonaws.com/overmind-orchestrator-repo:v3.0",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "RUN_STORE_BACKEND", "value": "memory" },
        { "name": "PORT", "value": "8000" }
      ],
      "secrets": [
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/GEMINI_API_KEY"
        },
        {
          "name": "MODEL_ID",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/MODEL_ID"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/OPENAI_API_KEY"
        },
        {
          "name": "OVERMIND_DATABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/OVERMIND_DATABASE_URL"
        },
        {
          "name": "OVERMIND_EMBEDDING_DIMS",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/OVERMIND_EMBEDDING_DIMS"
        },
        {
          "name": "OVERMIND_EMBEDDING_MODEL",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/OVERMIND_EMBEDDING_MODEL"
        },
        {
          "name": "NGROK_AUTHTOKEN",
          "valueFrom": "arn:aws:ssm:us-east-2:048270140082:parameter/overmind/NGROK_AUTHTOKEN"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/overmind",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
