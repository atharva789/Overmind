# ─── Google AI Studio (Gemini) ───
GEMINI_API_KEY=your-gemini-api-key

# ─── Supabase (Postgres) ───
OVERMIND_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── LLM endpoint (OpenAI-compatible, used by orchestrator + merge resolver) ───
OVERMIND_LLM_URL=
MODEL_ID=gpt-4o

# ─── Orchestrator (FastAPI on ECS Fargate) ───
OVERMIND_ORCHESTRATOR_URL=http://your-alb-dns.us-east-2.elb.amazonaws.com

# ─── GitHub (for merge conflict resolver) ───
GITHUB_TOKEN=your-github-token
GITHUB_REPO=your-org/your-repo
GITHUB_BASE_BRANCH=main

# ─── ngrok (for remote join) ───
NGROK_AUTHTOKEN=your-ngrok-token

# ─── GPU backend ───
OVERMIND_GPU_BACKEND=aws
OVERMIND_GPU_TYPE=T4

# ─── Embedding model ───
OVERMIND_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
OVERMIND_EMBEDDING_DIMS=1024

# ─── OpenAI API (fallback when OVERMIND_LLM_URL is unset) ───
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# ─── AWS (only needed for local CLI, ECS uses task roles) ───
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-2
